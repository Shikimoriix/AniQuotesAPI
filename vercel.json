{
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/docs", "destination": "/public/docs.html" },
    { "source": "/api-reference", "destination": "/public/api-reference.html" },
    { "source": "/examples", "destination": "/public/examples.html" },
    { "source": "/contribute", "destination": "/public/contribute.html" },
    { "source": "/privacy", "destination": "/public/privacy.html" },
    { "source": "/terms", "destination": "/public/terms.html" },
    { "source": "/status", "destination": "/public/status.html" },
    { "source": "/api/status", "destination": "/api/status.js" },
    { "source": "/v1/(.*)", "destination": "/api/v1/$1" },
    { "source": "/v2/(.*)", "destination": "/api/v2/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/v2/image",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/public/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "functions": {
    "api/v2/image.js": {
      "includeFiles": "fonts/**"
    }
  },
  "trailingSlash": false
}
